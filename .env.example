# PostgreSQL (Neon / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js + LINE Login
AUTH_SECRET="openssl rand -base64 32"
AUTH_LINE_ID="your-line-channel-id"
AUTH_LINE_SECRET="your-line-channel-secret"

# Cron (Vercel แนบ header นี้ให้อัตโนมัติเมื่อ deploy แล้ว)
CRON_SECRET="openssl rand -base64 32"

# Claude API — สำหรับฟีเจอร์อ่านโพยจากรูป (vision)
ANTHROPIC_API_KEY="sk-ant-..."
